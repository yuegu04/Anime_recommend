# 服务端 .env 模板：放到 /opt/anime/back-api/.env（该文件名已被 .gitignore 忽略，不会入库）
# 复制本文件为 .env 后按需修改

# ---- JWT ----
JWT_SECRET=请改成一段随机长字符串（如 openssl rand -hex 32）
JWT_EXPIRE_DAYS=7

# ---- 数据库（复用服务器上已有的 MySQL，监听 127.0.0.1:3306）----
DB_USER=root
DB_PWD=你的MySQL密码
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=media_recommend

# ---- 跨域允许的前端来源（同源反代下其实不触发，但填上更稳）----
# 用公网 IP 访问就填 http://你的服务器IP；有域名就填 https://你的域名
CORS_ORIGINS=http://你的服务器IP
